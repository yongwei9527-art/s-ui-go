* text=auto

# Keep source files stable across platforms.
*.go text eol=lf
*.mod text eol=lf
*.sum text eol=lf
*.ts text eol=lf
*.vue text eol=lf
*.js text eol=lf
*.cjs text eol=lf
*.mts text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.sh text eol=lf

# Windows scripts should keep CRLF line endings.
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Release/runtime artifacts are binary.
*.zip binary
*.tar.gz binary
*.7z binary
*.exe binary
*.dll binary
*.so binary
*.dylib binary
*.db binary
*.sqlite binary
*.sqlite3 binary